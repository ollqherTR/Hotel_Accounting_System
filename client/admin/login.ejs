<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Login | Hotel Accounting</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body class="auth-page">
  <div class="login-container">
    <h1>Admin Login</h1>
    <% if (error === 'invalid') { %>
      <div class="error-message">Invalid username or password</div>
    <% } else if (error === 'server') { %>
      <div class="error-message">Server error occurred</div>
    <% } %>
    <form action="/admin/login" method="POST">
      <input type="text" name="username" placeholder="Admin Username" required>
      <input type="password" name="password" placeholder="Password" required>
      <button type="submit">Login</button>
    </form>

    <section class="demo-info" aria-label="Demo account information">
      <h2>Hotel Accounting System</h2>
      <p>
        A web-based accounting solution for hotels — track revenue and expenses,
        calculate VAT, accommodation tax, and export Excel reports.
      </p>

      <div class="demo-section">
        <h3>Demo Accounts</h3>
        <p class="demo-note">All passwords: <strong>admin</strong></p>
        <ul>
          <li><strong>level3</strong> / admin → Level 3: Full access (dashboard, revenue, expenses, tax)</li>
          <li><strong>level2</strong> / admin → Level 2: Dashboard, revenue, expenses</li>
          <li><strong>level1</strong> / admin → Level 1: Dashboard only</li>
          <li><strong>level0</strong> / admin → Level 0: Restricted access</li>
        </ul>
      </div>

      <div class="demo-section">
        <h3>Admin Panel</h3>
        <ul>
          <li><strong>admin</strong> / admin → Full admin access (user management, logs)</li>
        </ul>
      </div>
    </section>

    <p><a href="/">Back to Home</a></p>
  </div>
  <%- include('../partials/footer') %>
</body>
</html>
